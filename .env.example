# Server Configuration
NODE_ENV=development
PORT=3003
SERVICE_NAME=video-service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eduhub_videos
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER_NAME=videos
AZURE_STORAGE_CONNECTION_STRING=

# Azure CDN Configuration (optional)
AZURE_CDN_ENDPOINT=
AZURE_CDN_PROFILE=

# Video Upload Configuration
MAX_FILE_SIZE=524288000
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,wmv,flv,mkv,webm
UPLOAD_TEMP_DIR=./uploads/temp

# SAS Token Configuration (for secure video URLs)
SAS_TOKEN_EXPIRY_HOURS=24
SAS_TOKEN_PERMISSIONS=r

# Logging
LOG_LEVEL=info

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# JWT Configuration (for authentication with auth-service)
JWT_SECRET=your_jwt_secret_key_here
JWT_ISSUER=eduhub-auth-service

# Service URLs (for microservice communication)
AUTH_SERVICE_URL=http://localhost:3001
CATALOG_SERVICE_URL=http://localhost:3002
